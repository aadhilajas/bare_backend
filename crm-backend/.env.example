# OpenAI-compatible API key (OpenAI or OpenRouter)
OPENAI_API_KEY=

# Optional — auto-detected for sk-or-* keys if left empty
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Channel stub service URL
CHANNEL_STUB_URL=http://localhost:8001

# Receipt callback URL (used by channel-stub)
CRM_RECEIPT_URL=http://localhost:8000/api/receipts

# SQLite database path
DATABASE_URL=sqlite:///./bare.db
