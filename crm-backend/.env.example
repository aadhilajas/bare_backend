# OpenAI-compatible API key (OpenAI or OpenRouter)
OPENAI_API_KEY=

# Optional — auto-detected for sk-or-* keys if left empty
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Channel stub service URL (ignored when EMBEDDED_CHANNEL_STUB=true)
CHANNEL_STUB_URL=http://localhost:8001

# Run delivery simulation inside crm-backend (for single-service Railway deploy).
# Optional — auto-fallback also runs when CHANNEL_STUB_URL is unreachable.
# EMBEDDED_CHANNEL_STUB=true

# Receipt callback URL (used by channel-stub and embedded simulator).
# Defaults to http://127.0.0.1:$PORT/api/receipts when unset (Railway-safe).
# CRM_RECEIPT_URL=http://127.0.0.1:8000/api/receipts

# SQLite database path
DATABASE_URL=sqlite:///./bare.db

# HTTP port (Railway injects this; used for default CRM_RECEIPT_URL)
# PORT=8000
